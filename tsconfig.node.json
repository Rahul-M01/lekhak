{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "outDir": "dist-electron"
  },
  "include": ["src/main/**/*.ts", "vite.config.ts", "electron-builder.yml"]
}
